# ============================================================================
# EMAC Project - Git Ignore Configuration
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/
*.log.*

# Environment variables
.env
.env.local
.env.*.local
App/.env

# PyInstaller build
build/
dist/
*.spec.backup
EMAC.spec

# Application specific
App/logs/
App/__pycache__/
App/*.log
App/documents/uploads/
App/database/backups/

# Database files
*.sql
*.sqlite
*.db
*.sql.gz
*.sql.zip
# Exception: Keep schema files
!App/database/schema/*.sql
!App/database/migrations/*.sql

# Backups et exports temporaires
*.backup
*.bak
*.tmp
*.old
exports/
temp/

# Build et tests temporaires
build-scripts/build/
build-scripts/dist/
session-reports/
tests/__pycache__/
nul

# Fichiers temporaires de travail à la racine (ne doivent pas être commités)
# Ces fichiers sont créés pendant les sessions de développement et doivent rester locaux
SCRIPTS_BUILD_RECREES.txt
RESUME_REORGANISATION.txt
BUILD_RAPIDE.txt
PLAN_REORGANISATION_*.md

# Anciennes locations de documentation (maintenant dans docs/)
# Ces patterns évitent de re-créer ces fichiers à la racine
DEMARRAGE_RAPIDE.md
BIENVENUE.md
REORGANISATION.md
STRUCTURE.md

# Rapports d'optimisation (maintenant dans docs/dev/optimisation-reports/)
CHANGELOG_OPTIMISATIONS.md
CHANGELOG_DB_OPTIMIZATION.md
OPTIMISATIONS_*.md
MONITORING_PERFORMANCE_APPLIQUE.md
INTEGRATIONS_OPTIMISATIONS_COMPLETEES.md
MIGRATION_CONTEXT_MANAGERS.md
RESUME_FINAL_OPTIMISATIONS.md
RESUME_OPTIMISATIONS.txt

# ============================================================================
# À CONSERVER DANS GIT
# ============================================================================
# App/                    - Code source de l'application
# docs/                   - Documentation du projet
# build-scripts/          - Scripts de build et analyse
# tests/                  - Scripts de test
# archives/               - Historique du projet (archivé)
# README.md               - Documentation principale
# CLAUDE.md               - Instructions pour Claude Code
# .gitignore              - Cette configuration
#
# À IGNORER
# session-reports/        - Rapports de sessions de travail (temporaires)
# temp/                   - Fichiers temporaires de build
