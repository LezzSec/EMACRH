# ============================================================================
# EMAC Project - Git Ignore Configuration
# ============================================================================

# Dossiers et fichiers exclus du repo (garder uniquement App/, README.md, .gitignore)
docs/
build-scripts/
build/
dist/
_archive/
.claude/
*.zip
CLAUDE.md

# Python - Cache et bytecode (pattern global récursif)
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/
*.log.*

# Environment variables
.env
.env.local
.env.*.local
App/.env
App/.env.encrypted
# IMPORTANT: Le fichier config_crypter.py contient la clé de chiffrement
# Il ne doit JAMAIS être commité avec la vraie clé
App/infrastructure/security/config_crypter.py

# PyInstaller build
build/
dist/
*.spec.backup
EMAC_*.spec

# Application specific
App/logs/
App/__pycache__/
App/*.log
App/documents/uploads/
App/database/backups/

# Database files
*.sql
*.sqlite
*.db
*.sql.gz
*.sql.zip
# Migrations
App/database/migrations/

# Backups et export temporaires
*.backup
*.bak
*.tmp
*.old
export/
**/export/
prompts/
**/prompts/
temp/

# Build et tests temporaires
build-scripts/build/
build-scripts/dist/
session-reports/
tests/__pycache__/

# Tests locaux uniquement
App/tests/
tests/

# Pytest cache (pattern global récursif)
**/.pytest_cache/
.pytest_cache/

# Fichiers résiduels Windows
**/nul
nul

# Session CSV exports
session_*.csv
**/session_*.csv

# Artefacts de build PyQt5 (anciens builds dans core/gui/)
App/core/gui/build/
App/core/gui/dist/

# Fichiers temporaires de travail à la racine (ne doivent pas être commités)
# Ces fichiers sont créés pendant les sessions de développement et doivent rester locaux
SCRIPTS_BUILD_RECREES.txt
RESUME_REORGANISATION.txt
BUILD_RAPIDE.txt
PLAN_REORGANISATION_*.md
AMELIORATION_*.md
VERIFICATION_*.md
COMMENT_*.md
test_*.py
launch_*.bat
TEST_*.bat
*.cwd
tmpclaude-*/

# Exception: Conserver les archives historiques
!archives/**/*.md

# Anciennes locations de documentation (maintenant dans docs/)
# Ces patterns évitent de re-créer ces fichiers à la racine
DEMARRAGE_RAPIDE.md
BIENVENUE.md
REORGANISATION.md
STRUCTURE.md

# Rapports d'optimisation (maintenant dans docs/dev/optimisation-reports/)
CHANGELOG_OPTIMISATIONS.md
CHANGELOG_DB_OPTIMIZATION.md
OPTIMISATIONS_*.md
MONITORING_PERFORMANCE_APPLIQUE.md
INTEGRATIONS_OPTIMISATIONS_COMPLETEES.md
MIGRATION_CONTEXT_MANAGERS.md
RESUME_FINAL_OPTIMISATIONS.md
RESUME_OPTIMISATIONS.txt

# Archive de fichiers non utilisés (nettoyage 2026-02-04)
_archive/

# ============================================================================
# À CONSERVER DANS GIT
# ============================================================================
# App/                    - Code source de l'application
# docs/                   - Documentation du projet
# build-scripts/          - Scripts de build et analyse
# README.md               - Documentation principale
# CLAUDE.md               - Instructions pour Claude Code
# .gitignore              - Cette configuration
#
# À IGNORER
# session-reports/        - Rapports de sessions de travail (temporaires)
# App/tests/              - Tests locaux non versionnés
# temp/                   - Fichiers temporaires de build
# _archive/               - Fichiers archivés (code mort, documents obsolètes)
