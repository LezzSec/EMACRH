-- Étape 1 : Créer une table temporaire avec les données CSV nettoyées
CREATE TEMPORARY TABLE temp_csv_import AS
SELECT 
    TRIM(NOMFAMILLE) as nom,
    TRIM(PRENOM) as prenom,
    CASE 
        WHEN SEXE = '1' THEN 'M'
        WHEN SEXE = '2' THEN 'F'
        ELSE 'NSP'
    END as sexe,
    STR_TO_DATE(NAISDT, '%Y-%m-%d') as date_naissance,
    STR_TO_DATE(ENTREEGROUPEDT, '%Y-%m-%d %H:%i:%s.%f') as date_entree,
    TRIM(EMAIL) as email,
    TRIM(GSM) as telephone,
    TRIM(ADRCPL1_0001) as adresse1,
    TRIM(CPOSTAL_0001) as cp_adresse,
    TRIM(VIL_0001) as ville_adresse,
    TRIM(PAY_0001) as pays_adresse,
    TRIM(COMNAIS) as ville_naissance,
    TRIM(CODEPAYSNAIS) as pays_naissance,
    TRIM(DEPARNAIS) as cp_naissance,
    TRIM(CODEPAYSNATION) as nationalite,
    ROW_NUMBER() OVER (
        PARTITION BY TRIM(NOMFAMILLE), TRIM(PRENOM), STR_TO_DATE(NAISDT, '%Y-%m-%d')
        ORDER BY STR_TO_DATE(ENTREEGROUPEDT, '%Y-%m-%d %H:%i:%s.%f') DESC
    ) as rn
FROM Classeur1
WHERE NOMFAMILLE IS NOT NULL 
  AND PRENOM IS NOT NULL
  AND TRIM(NOMFAMILLE) != ''
  AND TRIM(PRENOM) != '';

-- Étape 2 : Insérer les nouveaux opérateurs (éviter doublons)
INSERT INTO operateurs (nom, prenom, statut)
SELECT DISTINCT
    t.nom,
    t.prenom,
    'ACTIF' as statut
FROM temp_csv_import t
WHERE t.rn = 1  -- Prendre uniquement la ligne la plus récente par personne
  AND NOT EXISTS (
      -- Vérifier qu'il n'existe pas déjà dans la base
      SELECT 1 
      FROM operateurs o 
      WHERE UPPER(TRIM(o.nom)) = UPPER(t.nom)
        AND UPPER(TRIM(o.prenom)) = UPPER(t.prenom)
  );

-- Étape 3 : Insérer les infos complémentaires
INSERT INTO operateur_infos (
    operateur_id, 
    sexe, 
    date_naissance, 
    date_entree,
    email, 
    telephone, 
    adresse1, 
    cp_adresse, 
    ville_adresse, 
    pays_adresse,
    ville_naissance, 
    pays_naissance, 
    cp_naissance,
    nationalite
)
SELECT 
    o.id,
    t.sexe,
    t.date_naissance,
    t.date_entree,
    NULLIF(t.email, ''),
    NULLIF(t.telephone, ''),
    NULLIF(t.adresse1, ''),
    NULLIF(t.cp_adresse, ''),
    NULLIF(t.ville_adresse, ''),
    NULLIF(t.pays_adresse, ''),
    NULLIF(t.ville_naissance, ''),
    NULLIF(t.pays_naissance, ''),
    NULLIF(t.cp_naissance, ''),
    NULLIF(t.nationalite, '')
FROM temp_csv_import t
JOIN operateurs o ON UPPER(TRIM(o.nom)) = UPPER(t.nom)
                  AND UPPER(TRIM(o.prenom)) = UPPER(t.prenom)
WHERE t.rn = 1
  AND NOT EXISTS (
      SELECT 1 
      FROM operateur_infos oi 
      WHERE oi.operateur_id = o.id
  )
ON DUPLICATE KEY UPDATE
    -- Mettre à jour uniquement si les données CSV sont plus récentes ou plus complètes
    sexe = COALESCE(NULLIF(VALUES(sexe), 'NSP'), sexe),
    date_naissance = COALESCE(VALUES(date_naissance), date_naissance),
    date_entree = COALESCE(VALUES(date_entree), date_entree),
    email = COALESCE(NULLIF(VALUES(email), ''), email),
    telephone = COALESCE(NULLIF(VALUES(telephone), ''), telephone),
    adresse1 = COALESCE(NULLIF(VALUES(adresse1), ''), adresse1),
    cp_adresse = COALESCE(NULLIF(VALUES(cp_adresse), ''), cp_adresse),
    ville_adresse = COALESCE(NULLIF(VALUES(ville_adresse), ''), ville_adresse),
    pays_adresse = COALESCE(NULLIF(VALUES(pays_adresse), ''), pays_adresse),
    ville_naissance = COALESCE(NULLIF(VALUES(ville_naissance), ''), ville_naissance),
    pays_naissance = COALESCE(NULLIF(VALUES(pays_naissance), ''), pays_naissance),
    cp_naissance = COALESCE(NULLIF(VALUES(cp_naissance), ''), cp_naissance),
    nationalite = COALESCE(NULLIF(VALUES(nationalite), ''), nationalite);

-- Nettoyage
DROP TEMPORARY TABLE temp_csv_import;