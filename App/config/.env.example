# Configuration de la base de données EMAC
# Copier ce fichier en ".env" et remplir avec vos vraies valeurs

# Mot de passe MySQL (REQUIS)
EMAC_DB_PASSWORD=votre_mot_de_passe_ici

# Autres paramètres (optionnels - valeurs par défaut si non spécifiés)
EMAC_DB_HOST=localhost
# Utiliser le compte applicatif dédié (pas root) - voir migrations/021_create_app_user.sql
EMAC_DB_USER=emac_app
EMAC_DB_NAME=emac_db
EMAC_DB_PORT=3306

# Chemin vers les templates de documents (optionnel)
# Utiliser un chemin reseau partage pour un acces multi-utilisateurs
# Exemples:
#   EMAC_TEMPLATES_DIR=\\\\serveur\\partage\\EMAC\\templates
#   EMAC_TEMPLATES_DIR=S:\\EMAC\\templates
# EMAC_TEMPLATES_DIR=

# Coordonnées GPS de l'entreprise (pour le calcul des distances domicile-travail)
# Remplacer par les vraies coordonnées de l'établissement dans le .env de prod.
# Latitude/longitude de l'établissement principal
EMAC_COMPANY_LAT=43.4832
EMAC_COMPANY_LON=-1.5586
EMAC_COMPANY_NAME=EMAC Siège social

# Clé API OpenRouteService (optionnel — gratuit jusqu'à 2000 req/jour)
# Si non défini, le fallback OSRM public est utilisé (pas de SLA, dev uniquement).
# Obtenir une clé sur : https://openrouteservice.org/dev/#/signup
# EMAC_ORS_API_KEY=
